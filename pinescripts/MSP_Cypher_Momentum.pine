// © MarketScanner Pros — Cypher Momentum & Conviction Engine v1
// Replicates: Momentum (Volatility) + Conviction (Effort) + Interest (Pressure) panels
// 3-layer momentum scoring with multi-timeframe pulse detection

//@version=6
indicator("MSP — Cypher Momentum Engine", shorttitle="MSP Cypher Mom", overlay=false, max_labels_count=200)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

grp_mom = "Momentum Settings"
rsiLen      = input.int(14,  "RSI Length",        minval=5,  maxval=30,  group=grp_mom)
macdFast    = input.int(12,  "MACD Fast",         minval=5,  maxval=20,  group=grp_mom)
macdSlow    = input.int(26,  "MACD Slow",         minval=15, maxval=40,  group=grp_mom)
macdSig     = input.int(9,   "MACD Signal",       minval=3,  maxval=15,  group=grp_mom)
adxLen      = input.int(14,  "ADX Length",         minval=7,  maxval=30,  group=grp_mom)
stochLen    = input.int(14,  "Stochastic Length",   minval=5,  maxval=21,  group=grp_mom)
stochSmooth = input.int(3,   "Stochastic Smooth",   minval=1,  maxval=5,   group=grp_mom)

grp_vol = "Volume & Conviction"
volLen      = input.int(20,  "Volume MA Length",    minval=5,  maxval=50,  group=grp_vol)
cvdLen      = input.int(20,  "CVD Smooth Length",   minval=5,  maxval=50,  group=grp_vol)
oiSym       = input.symbol("", "Open Interest Symbol (optional)", group=grp_vol)

grp_efrt = "Effort / Pressure"
effortLen   = input.int(10,  "Effort Lookback",   minval=5,  maxval=30,  group=grp_efrt)
pressureLen = input.int(14,  "Pressure Lookback",  minval=5,  maxval=30,  group=grp_efrt)

grp_vis = "Display"
showTable   = input.bool(true, "Show Dashboard Table", group=grp_vis)
tablePos    = input.string("top_right", "Table Position", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=grp_vis)
showHist    = input.bool(true, "Show Momentum Histogram", group=grp_vis)
showBg      = input.bool(true, "Show Regime Background", group=grp_vis)
bgAlpha     = input.int(92,   "Background Alpha", minval=80, maxval=100, group=grp_vis)

// ═══════════════════════════════════════════════════════════════
// CORE CALCULATIONS
// ═══════════════════════════════════════════════════════════════

// --- RSI ---
rsiVal = ta.rsi(close, rsiLen)

// --- MACD ---
[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSig)

// --- ADX ---
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

// --- Stochastic ---
stochK = ta.sma(ta.stoch(close, high, low, stochLen), stochSmooth)
stochD = ta.sma(stochK, stochSmooth)

// --- EMA structure ---
ema5  = ta.ema(close, 5)
ema12 = ta.ema(close, 12)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)

// ═══════════════════════════════════════════════════════════════
// LAYER 1: MOMENTUM PULSE (15m-equivalent on current TF)
// ═══════════════════════════════════════════════════════════════

// RSI momentum zone
rsiMomentum = rsiVal > 55 ? 1 : rsiVal < 45 ? -1 : 0

// MACD histogram direction + acceleration
histAccel = histLine - histLine[1]
macdMomentum = histLine > 0 and histAccel > 0 ? 2 : histLine > 0 ? 1 : histLine < 0 and histAccel < 0 ? -2 : histLine < 0 ? -1 : 0

// Stochastic momentum
stochMom = stochK > 80 ? 1 : stochK < 20 ? -1 : stochK > stochD ? 0.5 : stochK < stochD ? -0.5 : 0.0

// ADX trend strength
isTrending = adxVal > 25
adxStrength = isTrending ? 1.0 : adxVal > 20 ? 0.5 : 0.0

// Raw pulse score [-10 to +10 range]
rawPulse = rsiMomentum * 2 + macdMomentum * 2 + stochMom * 2 + adxStrength * (close > ema21 ? 2 : -2)
pulsePct = rawPulse / 10.0 * 100 // normalize to -100..100

// State: BULL ACTIVE, BEAR ACTIVE, NEUTRAL
pulseIsBull = pulsePct > 20
pulseIsBear = pulsePct < -20
pulseLabel = pulseIsBull ? "BULL ACTIVE" : pulseIsBear ? "BEAR ACTIVE" : "NEUTRAL"

// ═══════════════════════════════════════════════════════════════
// LAYER 2: TREND MOMENTUM (10m equiv — slightly smoothed)
// ═══════════════════════════════════════════════════════════════

// EMA alignment score
emaAlign = (ema5 > ema12 ? 1 : -1) + (ema12 > ema21 ? 1 : -1) + (ema21 > ema50 ? 1 : -1)

// Price vs EMA ribbon
priceVsEma = close > ema5 ? 1 : close < ema5 ? -1 : 0

// MACD signal crossover recency
macdCrossUp = ta.crossover(macdLine, signalLine)
macdCrossDn = ta.crossunder(macdLine, signalLine)
barsSinceMacdUp = ta.barssince(macdCrossUp)
barsSinceMacdDn = ta.barssince(macdCrossDn)
macdCrossRecent = nz(barsSinceMacdUp) < 5 ? 1 : nz(barsSinceMacdDn) < 5 ? -1 : 0

rawTrend = emaAlign * 2 + priceVsEma + macdCrossRecent * 2 + (diPlus > diMinus ? 1 : -1) * adxStrength
trendPct = rawTrend / 8.0 * 100

trendIsBull = trendPct > 20
trendIsBear = trendPct < -20
trendLabel = trendIsBull ? "BULL ACTIVE" : trendIsBear ? "BEAR ACTIVE" : "NEUTRAL"

// Trend type
trendType = isTrending and trendIsBull ? "BULL CONTROL" : isTrending and trendIsBear ? "BEAR CONTROL" : "RANGING"

// ═══════════════════════════════════════════════════════════════
// LAYER 3: MACRO MOMENTUM (5m equiv — higher smoothing)
// ═══════════════════════════════════════════════════════════════

sma50  = ta.sma(close, 50)
sma200 = ta.sma(close, 200)
ema100 = ta.ema(close, 100)

macroAlign = (close > sma50 ? 1 : -1) + (close > sma200 ? 1 : -1) + (sma50 > sma200 ? 1 : -1) + (close > ema100 ? 1 : -1)
macroPct = macroAlign / 4.0 * 100

macroIsBull = macroPct > 25
macroIsBear = macroPct < -25
macroLabel = macroIsBull ? "BULL ACTIVE" : macroIsBear ? "BEAR ACTIVE" : "NEUTRAL"
macroType = macroIsBull ? "MACRO BULL" : macroIsBear ? "MACRO BEAR" : "TRANSITION"

// ═══════════════════════════════════════════════════════════════
// CONVICTION (EFFORT) LAYER
// ═══════════════════════════════════════════════════════════════

// Volume analysis — approximation of buy/sell volume
avgVol = ta.sma(volume, volLen)
volRatio = avgVol > 0 ? volume / avgVol : 1.0

// Buy/sell volume split (approximation from candle body vs range)
bodyRatio = math.abs(close - open) / math.max(high - low, 0.0001)
isBuyBar = close > open
isSellBar = close < open

// Volume state
buyVol = isBuyBar ? volume * bodyRatio : volume * (1 - bodyRatio)
sellVol = isSellBar ? volume * bodyRatio : volume * (1 - bodyRatio)

buyVolSma = ta.sma(buyVol, effortLen)
sellVolSma = ta.sma(sellVol, effortLen)

// Effort classification
effortRatio = buyVolSma > 0 ? sellVolSma / buyVolSma : 1.0
volIsHigh = volRatio > 1.5
volIsLow = volRatio < 0.7

convLongLabel = volIsHigh and isBuyBar ? "BUYS LONG" : isBuyBar ? "BUYS LONG" : "FLAT SIT"
convShortLabel = volIsHigh and isSellBar ? "SELLS SHORT" : isSellBar ? "SELLS SHORT" : "FLAT SIT"

// 15m effort
eff15 = volIsHigh and isBuyBar ? "HIGH EFFORT" : volIsHigh and isSellBar ? "HIGH EFFORT" : "NOISE"
// 10m effort
eff10 = volRatio > 1.2 and isBuyBar ? "TREND EFFORT" : volRatio > 1.2 and isSellBar ? "TREND EFFORT" : "LOW EFFORT"
// 5m effort
eff5 = volIsLow ? "NOISE" : "ACTIVE"

// ═══════════════════════════════════════════════════════════════
// INTEREST (PRESSURE) LAYER
// ═══════════════════════════════════════════════════════════════

// CVD Delta approximation (cumulative volume delta)
delta = close >= open ? volume : -volume
cvdRaw = ta.cum(delta)
cvdSmooth = ta.ema(cvdRaw, cvdLen)
cvdSlope = cvdSmooth - cvdSmooth[3]

// CVD state
cvdHittingAsk = cvdSlope > 0 and isBuyBar
cvdHittingBid = cvdSlope < 0 and isSellBar
cvdLabel = cvdHittingAsk ? "HITTING ASK" : cvdHittingBid ? "HITTING BID" : "NEUTRAL"
cvdPressure = cvdHittingAsk ? "STRUCTURAL PUSH" : cvdHittingBid ? "STRUCTURAL DUMP" : "BALANCED"

// OI Fuel (if OI symbol provided)
oiAvail = oiSym != ""
oiVal = oiAvail ? request.security(oiSym, timeframe.period, close) : 0.0
oiPrev = oiAvail ? request.security(oiSym, timeframe.period, close[1]) : 0.0
oiChange = oiAvail ? (oiVal - oiPrev) / math.max(oiPrev, 1) * 100 : 0.0
oiLabel = not oiAvail ? "N/A" : oiChange > 0.5 ? "NEW MONEY" : oiChange < -0.5 ? "CLOSING" : "FLAT"
oiPct = not oiAvail ? "" : str.tostring(math.round(oiChange * 100) / 100) + "%"

// Whale detection (volume spike + directional candle)
volSpike = volume > avgVol * 2.5
whaleBar = volSpike and math.abs(close - open) > ta.atr(14) * 0.8
whaleLabel = whaleBar and isBuyBar ? "WHALE FORCE" : whaleBar and isSellBar ? "WHALE DUMP" : "NORMAL"

// ═══════════════════════════════════════════════════════════════
// COMPOSITE MOMENTUM SCORE (0-100)
// ═══════════════════════════════════════════════════════════════

// Normalize all components to 0-100
pulseNorm = (pulsePct + 100) / 2
trendNorm = (trendPct + 100) / 2
macroNorm = (macroPct + 100) / 2

compositeScore = pulseNorm * 0.35 + trendNorm * 0.35 + macroNorm * 0.30
compSmooth = ta.ema(compositeScore, 3)

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════

// Zero line
hline(50, "Midline", color=color.new(color.gray, 60), linestyle=hline.style_dotted)
hline(70, "Bull Zone", color=color.new(color.green, 80), linestyle=hline.style_dotted)
hline(30, "Bear Zone", color=color.new(color.red, 80), linestyle=hline.style_dotted)

// Composite momentum
compColor = compSmooth > 65 ? color.new(#10B981, 0) : compSmooth > 55 ? color.new(#3B82F6, 0) : compSmooth > 45 ? color.new(#F59E0B, 0) : compSmooth > 35 ? color.new(#F97316, 0) : color.new(#EF4444, 0)
plot(compSmooth, "Momentum Score", color=compColor, linewidth=2)

// Pulse histogram (fast momentum)
histColor = pulseNorm > 60 ? color.new(#10B981, 40) : pulseNorm < 40 ? color.new(#EF4444, 40) : color.new(#64748B, 50)
plot(showHist ? pulseNorm : na, "Pulse", color=histColor, style=plot.style_columns)

// Background regime
bgColor = compSmooth > 65 ? color.new(#10B981, bgAlpha) : compSmooth < 35 ? color.new(#EF4444, bgAlpha) : color.new(color.gray, 97)
bgcolor(showBg ? bgColor : na)

// Whale markers
plotshape(whaleBar and isBuyBar, "Whale Buy", shape.diamond, location.top, color.new(#10B981, 20), size=size.tiny)
plotshape(whaleBar and isSellBar, "Whale Sell", shape.diamond, location.bottom, color.new(#EF4444, 20), size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// DASHBOARD TABLE
// ═══════════════════════════════════════════════════════════════

if showTable and barstate.islast
    tblPos = tablePos == "top_right" ? position.top_right : tablePos == "top_left" ? position.top_left : tablePos == "bottom_right" ? position.bottom_right : position.bottom_left

    var tbl = table.new(tblPos, 4, 12, bgcolor=color.new(#0F172A, 5), border_color=color.new(#334155, 30), border_width=1, frame_color=color.new(#10B981, 60), frame_width=1)

    headerBg = color.new(#1E293B, 0)
    green = color.new(#10B981, 0)
    red   = color.new(#EF4444, 0)
    amber = color.new(#F59E0B, 0)
    white = color.new(#E2E8F0, 0)
    dim   = color.new(#94A3B8, 0)
    panelBg = color.new(#0F172A, 10)

    // Helper: status color
    bullActive = color.new(#10B981, 0)
    bearActive = color.new(#EF4444, 0)
    neutral    = color.new(#94A3B8, 0)

    // ── MOMENTUM (VOLATILITY) ──
    table.cell(tbl, 0, 0, "METRIC", text_color=dim, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 1, 0, "LIVE SIGNAL", text_color=dim, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 2, 0, "ANALYSIS", text_color=dim, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 3, 0, "", bgcolor=headerBg)

    table.cell(tbl, 0, 1, "MOMENTUM (VOLATILITY)", text_color=green, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 1, 1, "", bgcolor=headerBg)
    table.cell(tbl, 2, 1, "", bgcolor=headerBg)
    table.cell(tbl, 3, 1, "", bgcolor=headerBg)

    // Pulse (fast)
    pulseClr = pulseIsBull ? bullActive : pulseIsBear ? bearActive : neutral
    table.cell(tbl, 0, 2, "Pulse", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 2, pulseLabel, text_color=pulseClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 2, "ACTIVE PULSE", text_color=pulseClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 2, "", bgcolor=panelBg)

    // Trend
    trendClr = trendIsBull ? bullActive : trendIsBear ? bearActive : neutral
    table.cell(tbl, 0, 3, "Trend", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 3, trendLabel, text_color=trendClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 3, trendType, text_color=trendClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 3, "", bgcolor=panelBg)

    // Macro
    macroClr = macroIsBull ? bullActive : macroIsBear ? bearActive : neutral
    table.cell(tbl, 0, 4, "Macro", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 4, macroLabel, text_color=macroClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 4, macroType, text_color=macroClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 4, "", bgcolor=panelBg)

    // ── CONVICTION (EFFORT) ──
    table.cell(tbl, 0, 5, "CONVICTION (EFFORT)", text_color=green, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 1, 5, "", bgcolor=headerBg)
    table.cell(tbl, 2, 5, "", bgcolor=headerBg)
    table.cell(tbl, 3, 5, "", bgcolor=headerBg)

    effClr = volIsHigh ? green : volIsLow ? red : amber
    table.cell(tbl, 0, 6, "Vol Effort", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 6, convLongLabel, text_color=isBuyBar ? green : red, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 6, eff15, text_color=effClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 6, "", bgcolor=panelBg)

    table.cell(tbl, 0, 7, "Vol Ratio", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 7, str.tostring(math.round(volRatio * 100) / 100) + "x", text_color=volRatio > 1.5 ? green : volRatio < 0.7 ? red : white, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 7, eff10, text_color=effClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 7, "", bgcolor=panelBg)

    // ── INTEREST (PRESSURE) ──
    table.cell(tbl, 0, 8, "INTEREST (PRESSURE)", text_color=green, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 1, 8, "", bgcolor=headerBg)
    table.cell(tbl, 2, 8, "", bgcolor=headerBg)
    table.cell(tbl, 3, 8, "", bgcolor=headerBg)

    cvdClr = cvdHittingAsk ? green : cvdHittingBid ? red : neutral
    table.cell(tbl, 0, 9, "CVD Delta", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 9, cvdLabel, text_color=cvdClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 9, cvdPressure, text_color=cvdClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 9, "", bgcolor=panelBg)

    oiClr = oiChange > 0.5 ? green : oiChange < -0.5 ? red : neutral
    table.cell(tbl, 0, 10, "OI Fuel", text_color=dim, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 1, 10, oiLabel + " [" + oiPct + "]", text_color=oiClr, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 2, 10, whaleLabel, text_color=whaleBar ? (isBuyBar ? green : red) : neutral, text_size=size.tiny, bgcolor=panelBg)
    table.cell(tbl, 3, 10, "", bgcolor=panelBg)

    // ── COMPOSITE ──
    compClr = compSmooth > 65 ? green : compSmooth > 55 ? color.new(#3B82F6, 0) : compSmooth > 45 ? amber : compSmooth > 35 ? color.new(#F97316, 0) : red
    table.cell(tbl, 0, 11, "COMPOSITE", text_color=dim, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 1, 11, str.tostring(math.round(compSmooth)) + "/100", text_color=compClr, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 2, 11, compSmooth > 65 ? "STRONG MOMENTUM" : compSmooth > 50 ? "BUILDING" : compSmooth > 35 ? "FADING" : "WEAK", text_color=compClr, text_size=size.tiny, bgcolor=headerBg)
    table.cell(tbl, 3, 11, "", bgcolor=headerBg)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(ta.crossover(compSmooth, 65), "Momentum Bull Cross", "MSP Cypher: Momentum crossed above 65 — bull regime")
alertcondition(ta.crossunder(compSmooth, 35), "Momentum Bear Cross", "MSP Cypher: Momentum crossed below 35 — bear regime")
alertcondition(whaleBar and isBuyBar, "Whale Buy Detected", "MSP Cypher: Whale buy volume detected")
alertcondition(whaleBar and isSellBar, "Whale Sell Detected", "MSP Cypher: Whale sell volume detected")
alertcondition(cvdHittingAsk and volIsHigh, "Strong Ask Pressure", "MSP Cypher: CVD hitting ask with high effort")
