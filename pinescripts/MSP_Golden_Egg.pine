// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// © MarketScanner Pros — Golden Egg 4-Pillar Scoring System v2
// Structure (30%) + Flow (25%) + Momentum (20%) + Risk (25%) + Cohesion Penalty
// Display Modes: Clean / Pro / Diagnostic — Verdict-first decision card

//@version=6
indicator("MSP — Golden Egg Score", shorttitle="MSP Golden Egg", overlay=false, max_labels_count=200)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

grp_struct = "Pillar 1: Structure (30%)"
ema9Len    = input.int(9,   "EMA 9",   minval=3,  maxval=20,  group=grp_struct)
ema21Len   = input.int(21,  "EMA 21",  minval=10, maxval=50,  group=grp_struct)
ema55Len   = input.int(55,  "EMA 55",  minval=30, maxval=100, group=grp_struct)
ema200Len  = input.int(200, "EMA 200", minval=100, maxval=300, group=grp_struct)
adxLen     = input.int(14,  "ADX Length", minval=7, maxval=30, group=grp_struct)

grp_flow = "Pillar 2: Flow (25%)"
mfiLen     = input.int(14,  "MFI Length",  minval=7, maxval=30, group=grp_flow)
obvSmaLen  = input.int(20,  "OBV SMA",    minval=10, maxval=50, group=grp_flow)

grp_mom = "Pillar 3: Momentum (20%)"
rsiLen     = input.int(14,  "RSI Length",      minval=7, maxval=30, group=grp_mom)
macdFast   = input.int(12,  "MACD Fast",       minval=5, maxval=20, group=grp_mom)
macdSlow   = input.int(26,  "MACD Slow",       minval=15, maxval=40, group=grp_mom)
macdSig    = input.int(9,   "MACD Signal",     minval=5, maxval=15, group=grp_mom)
stochLen   = input.int(14,  "Stochastic %K",   minval=5, maxval=21, group=grp_mom)

grp_risk = "Pillar 4: Risk (25%)"
atrLen     = input.int(14,  "ATR Length",  minval=7, maxval=30, group=grp_risk)
bbLen      = input.int(13,  "BB Len (BBWP)", minval=5, maxval=50, group=grp_risk)
bbLookback = input.int(252, "BBWP Lookback", minval=50, maxval=500, group=grp_risk)

grp_thres = "Thresholds"
goldenMin  = input.float(75, "Golden Egg Min Score", minval=50, maxval=95, group=grp_thres)
silverMin  = input.float(60, "Silver Egg Min Score", minval=40, maxval=80, group=grp_thres)
rrTarget   = input.float(2.0, "Min R:R Required",    minval=1.0, maxval=5.0, step=0.5, group=grp_thres)

grp_vis         = "Visual Settings"
uiMode          = input.string("Clean", "Display Mode", options=["Clean", "Pro", "Diagnostic"], group=grp_vis)
showTable       = input.bool(true,  "Show Verdict Table", group=grp_vis)
showBg          = input.bool(true,  "Show Verdict Background", group=grp_vis)
showLabels      = input.bool(true,  "Show Verdict Labels", group=grp_vis)
showPillars     = input.bool(true,  "Show Pillar Plots", group=grp_vis)
showSqueeze     = input.bool(false, "Show Squeeze Markers", group=grp_vis)
showMinorMarks  = input.bool(false, "Show Minor Diagnostic Markers", group=grp_vis)
showLastBarLbl  = input.bool(false, "Show Last-Bar Verdict Label", group=grp_vis)
bgTransparency  = input.int(95, "Background Transparency", minval=85, maxval=100, group=grp_vis)

// Mode flags
isCleanMode = uiMode == "Clean"
isProMode   = uiMode == "Pro"
isDiagMode  = uiMode == "Diagnostic"

// ═══════════════════════════════════════════════════════════════
// CORE CALCULATIONS
// ═══════════════════════════════════════════════════════════════

ema9   = ta.ema(close, ema9Len)
ema21  = ta.ema(close, ema21Len)
ema55  = ta.ema(close, ema55Len)
ema200 = ta.ema(close, ema200Len)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
rsiVal = ta.rsi(close, rsiLen)
[macdLine, sigLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSig)
stK       = ta.stoch(close, high, low, stochLen)
stKSmooth = ta.sma(stK, 3)
stDSmooth = ta.sma(stKSmooth, 3)
mfiVal = ta.mfi(hlc3, mfiLen)
obvVal = ta.obv
obvSma = ta.sma(obvVal, obvSmaLen)
atrVal = ta.atr(atrLen)
volSma = ta.sma(volume, 20)
volRatio = volSma > 0 ? volume / volSma : 1.0

// BBWP
bbBasis_  = ta.sma(close, bbLen)
bbDev_    = ta.stdev(close, bbLen) * 2.0
bbwWidth_ = bbBasis_ != 0 ? (2 * bbDev_) / bbBasis_ : 0.0

countBelowGE(src, length) =>
    cnt = 0
    for i = 1 to length
        cnt += src[i] <= src ? 1 : 0
    cnt

bbwpRaw = bbLookback > 0 ? countBelowGE(bbwWidth_, bbLookback) / bbLookback * 100 : 50.0
bbwp    = math.max(0.0, math.min(100.0, bbwpRaw))

// Squeeze
kcB = ta.sma(close, 20)
kcR = ta.atr(20) * 1.5
bbU = bbBasis_ + bbDev_
bbL = bbBasis_ - bbDev_
isSqueeze = bbL > (kcB - kcR) and bbU < (kcB + kcR)

// NATR (normalized ATR)
natr = atrVal / close * 100

// ═══════════════════════════════════════════════════════════════
// PILLAR 1: STRUCTURE (0-100, weight 30%)
// ═══════════════════════════════════════════════════════════════

// EMA ribbon alignment (0-30)
ribbonBull = ema9 > ema21 and ema21 > ema55 and ema55 > ema200
ribbonBear = ema9 < ema21 and ema21 < ema55 and ema55 < ema200
partialBull = ema9 > ema21 and close > ema200
partialBear = ema9 < ema21 and close < ema200
emaScore = ribbonBull or ribbonBear ? 30.0 : partialBull or partialBear ? 20.0 : close > ema200 or close < ema200 ? 10.0 : 5.0

// ADX trend strength (0-25)
adxScore = adxVal >= 40 ? 25.0 : adxVal >= 30 ? 20.0 : adxVal >= 25 ? 15.0 : adxVal >= 20 ? 10.0 : 5.0

// DI separation (0-20)
diSep = math.abs(diPlus - diMinus)
diScore = diSep > 20 ? 20.0 : diSep > 15 ? 15.0 : diSep > 10 ? 10.0 : diSep > 5 ? 5.0 : 0.0

// Price position relative to structure (0-15)
priceAboveAll = close > ema9 and close > ema21 and close > ema55
priceBelowAll = close < ema9 and close < ema21 and close < ema55
posScore = priceAboveAll or priceBelowAll ? 15.0 : close > ema21 or close < ema21 ? 8.0 : 3.0

// Higher high / lower low structure (0-10)
hh = high > ta.highest(high, 10)[1]
ll = low < ta.lowest(low, 10)[1]
hhllScore = hh or ll ? 10.0 : 5.0

structurePillar = math.min(100.0, emaScore + adxScore + diScore + posScore + hhllScore)

// ═══════════════════════════════════════════════════════════════
// PILLAR 2: FLOW (0-100, weight 25%)
// ═══════════════════════════════════════════════════════════════

// Volume confirmation (0-30)
volFlowScore = volRatio > 2.0 ? 30.0 : volRatio > 1.5 ? 25.0 : volRatio > 1.2 ? 18.0 : volRatio > 1.0 ? 10.0 : 5.0

// OBV trend (0-25)
obvTrend = obvVal > obvSma ? 25.0 : 10.0

// MFI flow (0-25)
mfiFlow = mfiVal > 70 ? 25.0 : mfiVal > 60 ? 20.0 : mfiVal > 50 ? 15.0 : mfiVal > 40 ? 10.0 : 5.0
// Flip for bearish setups
mfiFlowAdj = close < ema21 ? (mfiVal < 30 ? 25.0 : mfiVal < 40 ? 20.0 : mfiVal < 50 ? 15.0 : 10.0) : mfiFlow

// Volume trend (3-bar rising) (0-20)
volRising = volume > volume[1] and volume[1] > volume[2]
volFalling = volume < volume[1] and volume[1] < volume[2]
volTrendScore = volRising ? 20.0 : volFalling ? 5.0 : 12.0

flowPillar = math.min(100.0, volFlowScore + obvTrend + mfiFlowAdj + volTrendScore)

// ═══════════════════════════════════════════════════════════════
// PILLAR 3: MOMENTUM (0-100, weight 20%)
// ═══════════════════════════════════════════════════════════════

// RSI in trend zone (0-30)
rsiMom = rsiVal > 55 and rsiVal < 75 ? 30.0 :  // bullish sweet spot
     rsiVal >= 75 ? 15.0 :                       // overbought — risky
     rsiVal > 45 and rsiVal <= 55 ? 20.0 :       // neutral
     rsiVal >= 25 and rsiVal <= 45 ? 30.0 :       // bearish sweet spot (for shorts)
     15.0                                          // oversold — risky

// MACD alignment (0-25)
macdStrong = macdLine > sigLine and histLine > 0 and histLine > nz(histLine[1])
macdWeak   = macdLine < sigLine and histLine < 0 and histLine < nz(histLine[1])
macdMom = macdStrong or macdWeak ? 25.0 : macdLine > sigLine or macdLine < sigLine ? 15.0 : 5.0

// Stochastic momentum (0-25)
stochMom = stKSmooth > stDSmooth and stKSmooth > 50 ? 25.0 :
     stKSmooth < stDSmooth and stKSmooth < 50 ? 25.0 :  // bearish momentum
     stKSmooth > stDSmooth ? 15.0 :
     stKSmooth < stDSmooth ? 15.0 : 8.0

// ROC (0-20)
roc12 = ta.roc(close, 12)
rocMom = math.abs(roc12) > 10 ? 20.0 : math.abs(roc12) > 5 ? 15.0 : math.abs(roc12) > 2 ? 10.0 : 5.0

momentumPillar = math.min(100.0, rsiMom + macdMom + stochMom + rocMom)

// ═══════════════════════════════════════════════════════════════
// PILLAR 4: RISK (0-100, weight 25%) — INVERTED: higher = lower risk = better
// ═══════════════════════════════════════════════════════════════

// BBWP risk (0-30): compression = low risk/high reward, climax = high risk
bbwpRisk = bbwp < 15 ? 30.0 :   // compressed — ideal
     bbwp < 30 ? 25.0 :
     bbwp < 50 ? 20.0 :
     bbwp < 70 ? 15.0 :
     bbwp < 90 ? 8.0 :
     0.0                          // climax — worst

// Squeeze bonus (0-15)
sqzRisk = isSqueeze ? 15.0 : bbwp < 20 ? 8.0 : 0.0

// ATR normalization — moderate volatility preferred (0-20)
natrRisk = natr < 1 ? 10.0 :    // too quiet
     natr < 2 ? 20.0 :           // ideal
     natr < 3 ? 15.0 :
     natr < 5 ? 10.0 :
     5.0                          // too volatile

// R:R assessment (0-20) — based on ATR distance to potential targets
stopATR = atrVal * 1.5
targetATR = atrVal * 3.0
impliedRR = stopATR > 0 ? targetATR / stopATR : 0
rrRisk = impliedRR >= 3 ? 20.0 : impliedRR >= 2 ? 15.0 : impliedRR >= 1.5 ? 10.0 : 5.0

// Exhaustion penalty (0-15): deduct if stoch + RSI both extreme
noExhaustion = (rsiVal > 30 and rsiVal < 70) and (stKSmooth > 20 and stKSmooth < 80)
exhPenalty = noExhaustion ? 15.0 : 5.0

riskPillar = math.min(100.0, bbwpRisk + sqzRisk + natrRisk + rrRisk + exhPenalty)

// ═══════════════════════════════════════════════════════════════
// GOLDEN EGG COMPOSITE (0-100)
// ═══════════════════════════════════════════════════════════════

goldenEgg = structurePillar * 0.30 + flowPillar * 0.25 + momentumPillar * 0.20 + riskPillar * 0.25
goldenEgg := math.max(0.0, math.min(100.0, goldenEgg))

// ═══════════════════════════════════════════════════════════════
// COHESION PENALTY — Reward pillar alignment
// ═══════════════════════════════════════════════════════════════

pillarMax = math.max(math.max(structurePillar, flowPillar), math.max(momentumPillar, riskPillar))
pillarMin = math.min(math.min(structurePillar, flowPillar), math.min(momentumPillar, riskPillar))
pillarSpread = pillarMax - pillarMin

cohesionPenalty = pillarSpread > 40 ? 10.0 :
     pillarSpread > 30 ? 7.0 :
     pillarSpread > 20 ? 4.0 :
     0.0

goldenEggAdj = math.max(0.0, goldenEgg - cohesionPenalty)

// ═══════════════════════════════════════════════════════════════
// VERDICTS & DIRECTION
// ═══════════════════════════════════════════════════════════════

isGolden = goldenEggAdj >= goldenMin
isSilver = goldenEggAdj >= silverMin and not isGolden
goldenNew = isGolden and not isGolden[1]
silverNew = isSilver and not isSilver[1]

// Direction
isBullSetup = close > ema21 and rsiVal > 50 and diPlus > diMinus
isBearSetup = close < ema21 and rsiVal < 50 and diMinus > diPlus
directionAligned = isBullSetup ? 1 : isBearSetup ? -1 : 0
sideStr = isBullSetup ? "BULL" : isBearSetup ? "BEAR" : "NEUTRAL"

// Pillar alignment filter
threePillarsStrong = (structurePillar >= 55 ? 1 : 0) + (flowPillar >= 55 ? 1 : 0) + (momentumPillar >= 55 ? 1 : 0) + (riskPillar >= 55 ? 1 : 0) >= 3

// ═══════════════════════════════════════════════════════════════
// ACTION ENGINE — GO / WATCH / PASS / AVOID
// ═══════════════════════════════════════════════════════════════

action = goldenEggAdj >= goldenMin and directionAligned != 0 and riskPillar >= 60 and structurePillar >= 60 ? "GO" :
     goldenEggAdj >= silverMin and directionAligned != 0 ? "WATCH" :
     riskPillar < 40 ? "AVOID" :
     "PASS"

actionColor = action == "GO" ? color.new(#10B981, 0) :
     action == "WATCH" ? color.new(color.yellow, 0) :
     action == "AVOID" ? color.new(color.red, 0) :
     color.new(color.gray, 0)

verdict = isGolden ? "GOLD" : isSilver ? "SILVER" : "NONE"

grade = goldenEggAdj >= 80 ? "A+" :
     goldenEggAdj >= 72 ? "A" :
     goldenEggAdj >= 65 ? "B" :
     goldenEggAdj >= silverMin ? "C" :
     "D"

// ═══════════════════════════════════════════════════════════════
// PLOTS — Layered for visual hierarchy (Phase 11 order)
// ═══════════════════════════════════════════════════════════════

// 1. Verdict background (softest layer)
bgCol = showBg ? (isGolden ? color.new(color.yellow, bgTransparency) :
     (isSilver and not isCleanMode) ? color.new(color.white, math.min(bgTransparency + 2, 100)) :
     na) : na
bgcolor(bgCol, title="Verdict BG")

// 2. Threshold lines
hline(silverMin, "Silver Threshold", color=color.new(color.white, 70), linestyle=hline.style_dashed)
hline(goldenMin, "Gold Threshold",   color=color.new(color.yellow, 65), linestyle=hline.style_dashed)

// 3. Pillar lines (mode-aware — no filled areas)
plot(showPillars and (isProMode or isDiagMode) ? structurePillar : na, "Structure", color=color.new(color.aqua, 35), linewidth=1)
plot(showPillars and isDiagMode ? flowPillar : na, "Flow", color=color.new(color.blue, 45), linewidth=1)
plot(showPillars and isDiagMode ? momentumPillar : na, "Momentum", color=color.new(color.yellow, 45), linewidth=1)
plot(showPillars and (isProMode or isDiagMode) ? riskPillar : na, "Risk", color=color.new(#10B981, 35), linewidth=1)

// 4. Total Golden Egg line (main character)
geColor = goldenEggAdj >= goldenMin ? color.new(color.yellow, 0) :
     goldenEggAdj >= silverMin ? color.new(color.white, 0) :
     color.new(color.orange, 0)
plot(goldenEggAdj, "Golden Egg Score", color=geColor, linewidth=3)

// 5. Squeeze markers (optional)
plotshape(showSqueeze and not isCleanMode and isSqueeze, "Squeeze", shape.diamond, location.bottom, color.new(color.fuchsia, 40), size=size.tiny)

// 6. Verdict labels (sparse, earned — threePillarsStrong gated)
plotshape(showLabels and goldenNew and threePillarsStrong and isBullSetup, "Golden Bull", shape.labelup, location.bottom, color.new(color.yellow, 0), text="🥚 BULL", textcolor=color.black, size=size.small)
plotshape(showLabels and goldenNew and threePillarsStrong and isBearSetup, "Golden Bear", shape.labeldown, location.top, color.new(color.yellow, 0), text="🥚 BEAR", textcolor=color.black, size=size.small)
plotshape(showLabels and silverNew and not isCleanMode and isBullSetup, "Silver Bull", shape.labelup, location.bottom, color.new(color.white, 10), text="🥈 BULL", textcolor=color.black, size=size.tiny)
plotshape(showLabels and silverNew and not isCleanMode and isBearSetup, "Silver Bear", shape.labeldown, location.top, color.new(color.white, 10), text="🥈 BEAR", textcolor=color.black, size=size.tiny)

// 7. Transition action markers (Pro/Diagnostic only)
if (isProMode or isDiagMode) and goldenNew and action == "GO"
    label.new(bar_index, goldenEggAdj + 3, "GO",
         style=label.style_label_down, color=color.new(#10B981, 0),
         textcolor=color.white, size=size.tiny)
if isDiagMode and silverNew and action == "WATCH"
    label.new(bar_index, goldenEggAdj + 3, "WATCH",
         style=label.style_label_down, color=color.new(color.yellow, 10),
         textcolor=color.black, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// TABLE — Verdict Card
// ═══════════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(#0F172A, 8), frame_width=1, frame_color=color.new(color.gray, 70))

if barstate.islast and showTable
    // Row 0: ACTION
    table.cell(dash, 0, 0, "ACTION",    text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 0, action,      text_color=actionColor, text_size=size.small)

    // Row 1: VERDICT
    verdCol = isGolden ? color.yellow : isSilver ? color.white : color.gray
    table.cell(dash, 0, 1, "VERDICT",   text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 1, verdict,     text_color=verdCol, text_size=size.small)

    // Row 2: SCORE
    table.cell(dash, 0, 2, "SCORE",     text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(goldenEggAdj, "#.1"), text_color=color.white, text_size=size.small)

    // Row 3: GRADE
    grCol = grade == "A+" ? #10B981 : grade == "A" ? color.lime : grade == "B" ? color.yellow : color.gray
    table.cell(dash, 0, 3, "GRADE",     text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 3, grade,       text_color=grCol, text_size=size.small)

    // Row 4: COHESION
    cohCol = pillarSpread < 20 ? #10B981 : pillarSpread < 30 ? color.yellow : color.red
    table.cell(dash, 0, 4, "COHESION",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(100 - pillarSpread, "#.0"), text_color=cohCol, text_size=size.small)

    // Row 5: STRUCTURE
    table.cell(dash, 0, 5, "STRUCTURE", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(structurePillar, "#.1"), text_color=color.aqua, text_size=size.small)

    // Row 6: FLOW
    table.cell(dash, 0, 6, "FLOW",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(flowPillar, "#.1"), text_color=color.blue, text_size=size.small)

    // Row 7: MOMENTUM
    table.cell(dash, 0, 7, "MOMENTUM",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(momentumPillar, "#.1"), text_color=color.yellow, text_size=size.small)

    // Row 8: RISK
    table.cell(dash, 0, 8, "RISK",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(riskPillar, "#.1"), text_color=#10B981, text_size=size.small)

    // Row 9: SIDE
    sdCol = sideStr == "BULL" ? #10B981 : sideStr == "BEAR" ? color.red : color.gray
    table.cell(dash, 0, 9, "SIDE",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 9, sideStr,     text_color=sdCol, text_size=size.small)

// ═══════════════════════════════════════════════════════════════
// LAST-BAR VERDICT LABEL (optional)
// ═══════════════════════════════════════════════════════════════

if showLastBarLbl and barstate.islast
    label.new(bar_index, goldenEggAdj, action + " | " + verdict + " | " + sideStr,
         style=label.style_label_left,
         textcolor=color.white,
         color=color.new(#111827, 10),
         size=size.small)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(goldenNew and isBullSetup, "Golden Egg Bull", "MSP Golden Egg: GOLDEN bullish setup detected!")
alertcondition(goldenNew and isBearSetup, "Golden Egg Bear", "MSP Golden Egg: GOLDEN bearish setup detected!")
alertcondition(silverNew and isBullSetup, "Silver Egg Bull", "MSP Golden Egg: SILVER bullish setup detected")
alertcondition(silverNew and isBearSetup, "Silver Egg Bear", "MSP Golden Egg: SILVER bearish setup detected")
alertcondition(goldenEggAdj >= 85,        "A-Grade Setup",   "MSP Golden Egg: A-Grade setup — score ≥ 85")
alertcondition(action == "GO",            "Action GO",       "MSP Golden Egg: Action verdict is GO")
alertcondition(action == "AVOID",         "Action AVOID",    "MSP Golden Egg: Action verdict is AVOID")
