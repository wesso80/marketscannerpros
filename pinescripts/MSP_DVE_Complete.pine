// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// © MarketScanner Pros — Dynamic Volatility Engine (DVE) v2
// Full 5-layer implementation: BBWP, VHM, Vol Regime, Squeeze, Phase Persistence,
// Signal Triggering, Breakout Readiness, Exhaustion Risk, Trap Detection
// Display Modes: Clean / Pro / Diagnostic — Verdict-first table

//@version=6
indicator("MSP — Dynamic Volatility Engine", shorttitle="MSP DVE", overlay=false, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

grp_bbwp   = "BBWP Settings"
bbLen      = input.int(13,   "BB Length",         minval=5,  maxval=50,  group=grp_bbwp)
lookback   = input.int(252,  "Percentile Lookback", minval=50, maxval=500, group=grp_bbwp)
smaPeriod  = input.int(5,    "BBWP SMA Period",   minval=2,  maxval=20,  group=grp_bbwp)
stdMult    = input.float(2.0,"BB Std Multiplier",  minval=0.5,maxval=4.0, step=0.5, group=grp_bbwp)

grp_thresh = "Regime Thresholds"
compThresh  = input.float(15.0, "Compression (<)", minval=1, maxval=40, group=grp_thresh)
expThresh   = input.float(70.0, "Expansion (>)",   minval=50, maxval=95, group=grp_thresh)
climThresh  = input.float(90.0, "Climax (≥)",      minval=75, maxval=99, group=grp_thresh)

grp_dir    = "Directional Bias"
biasThresh  = input.float(15.0, "Bias Threshold (±)", minval=5, maxval=40, group=grp_dir)
adxLen      = input.int(14,  "ADX Length",        minval=7,  maxval=30,  group=grp_dir)
stochK_len  = input.int(14,  "Stochastic %K",     minval=5,  maxval=21,  group=grp_dir)
stochK_sm   = input.int(3,   "Stochastic Smooth", minval=1,  maxval=5,   group=grp_dir)
stochD_sm   = input.int(3,   "Signal %D",         minval=1,  maxval=5,   group=grp_dir)

grp_kc     = "Keltner / Squeeze"
kcLen       = input.int(20,  "Keltner Length",    minval=10, maxval=50,  group=grp_kc)
kcMult      = input.float(1.5,"Keltner Multiplier", minval=0.5, maxval=3.0, step=0.5, group=grp_kc)

grp_vis        = "Visual Settings"
uiMode         = input.string("Pro", "Display Mode", options=["Clean", "Pro", "Diagnostic"], group=grp_vis)
showTable      = input.bool(true,  "Show Verdict Table", group=grp_vis)
showPressure   = input.bool(true,  "Show Pressure Ribbon", group=grp_vis)
showVHM        = input.bool(true,  "Show VHM Histogram", group=grp_vis)
showBg         = input.bool(true,  "Show Regime Background", group=grp_vis)
showExhaust    = input.bool(true,  "Show Exhaustion Warnings", group=grp_vis)
showMinorMarks = input.bool(false, "Show Minor Diagnostic Markers", group=grp_vis)
showLastBarLbl = input.bool(false, "Show Last-Bar Summary Label", group=grp_vis)
bgTransparency = input.int(95, "Background Transparency", minval=85, maxval=100, group=grp_vis)

// Mode flags
isCleanMode = uiMode == "Clean"
isProMode   = uiMode == "Pro"
isDiagMode  = uiMode == "Diagnostic"

// ═══════════════════════════════════════════════════════════════
// LAYER 1: BBWP — Bollinger Band Width Percentile
// ═══════════════════════════════════════════════════════════════

basis      = ta.sma(close, bbLen)
dev        = ta.stdev(close, bbLen) * stdMult
bbUpper    = basis + dev
bbLower    = basis - dev
bbWidth    = basis != 0 ? (bbUpper - bbLower) / basis : 0.0

// Percentile ranking over lookback window
countBelow(src, length) =>
    cnt = 0
    for i = 1 to length
        cnt += src[i] <= src ? 1 : 0
    cnt

rawPctRank = lookback > 0 ? countBelow(bbWidth, lookback) / lookback * 100 : 50.0
bbwp       = math.max(0.0, math.min(100.0, rawPctRank))
bbwpSma    = ta.sma(bbwp, smaPeriod)

// VHM — Volatility Histogram Momentum
vhmRoc       = bbwp - nz(bbwp[1])
vhmSmoothed  = ta.sma(vhmRoc, smaPeriod)
vhmAccel     = vhmSmoothed - nz(vhmSmoothed[1])
vhmDirection = vhmAccel > 0.01 ? 1 : vhmAccel < -0.01 ? -1 : 0  // 1=accel, -1=decel, 0=flat

// Vol Regime Classification
volRegime = bbwp >= climThresh ? 4 :
     bbwp > expThresh  ? 3 :
     bbwp < compThresh and vhmDirection == 1 ? 5 :
     bbwp < compThresh ? 1 :
     2  // 1=compression, 2=neutral, 3=expansion, 4=climax, 5=transition

regimeConfidence = volRegime == 1 ? (compThresh - bbwp) / compThresh * 100 :
     volRegime == 4 ? math.max(50, (bbwp - climThresh) / (100 - climThresh) * 100) :
     volRegime == 3 ? (bbwp - expThresh) / (climThresh - expThresh) * 100 :
     volRegime == 5 ? 50.0 :
     math.min((bbwp - compThresh), (expThresh - bbwp)) / ((expThresh - compThresh) / 2) * 100

regimeConf = math.max(0.0, math.min(100.0, regimeConfidence))

// ═══════════════════════════════════════════════════════════════
// LAYER 1b: Squeeze Detection (BB inside Keltner Channel)
// ═══════════════════════════════════════════════════════════════

kcBasis  = ta.sma(close, kcLen)
kcRange  = ta.atr(kcLen) * kcMult
kcUpper  = kcBasis + kcRange
kcLower  = kcBasis - kcRange

isSqueeze     = bbLower > kcLower and bbUpper < kcUpper
squeezeFiring = isSqueeze[1] and not isSqueeze  // squeeze just released

// ═══════════════════════════════════════════════════════════════
// LAYER 2: Directional Bias (-100 to +100)
// ═══════════════════════════════════════════════════════════════

// Stochastic
stK        = ta.stoch(close, high, low, stochK_len)
stKSmooth  = ta.sma(stK, stochK_sm)
stDSmooth  = ta.sma(stKSmooth, stochD_sm)
stSpread   = stKSmooth - stDSmooth
stKSlope   = stKSmooth - nz(stKSmooth[1])
stDSlope   = stDSmooth - nz(stDSmooth[1])

stochScore = 0.0
stochScore += stSpread > 0 ? 4.0 : stSpread < 0 ? -4.0 : 0.0
stochScore += stKSlope > 0 ? 3.0 : stKSlope < 0 ? -3.0 : 0.0
stochScore += stDSlope > 0 ? 3.0 : stDSlope < 0 ? -3.0 : 0.0
stochScore += stKSmooth > 50 and stSpread > 0 ? 5.0 : stKSmooth < 50 and stSpread < 0 ? -5.0 : 0.0
stochScore := math.max(-15.0, math.min(15.0, stochScore))

// Trend Structure
sma20      = ta.sma(close, 20)
sma50      = ta.sma(close, 50)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

trendScore = 0.0
trendScore += close > sma20 ? 5.0 : close < sma20 ? -5.0 : 0.0
trendScore += close > sma50 ? 5.0 : close < sma50 ? -5.0 : 0.0
trendScore += sma20 > sma50  ? 5.0 : sma20 < sma50  ? -5.0 : 0.0
trendScore += adxVal >= 25 ? (diPlus > diMinus ? 5.0 : -5.0) : 0.0
trendScore := math.max(-20.0, math.min(20.0, trendScore))

// Volume Expansion
volSma20    = ta.sma(volume, 20)
volRatio    = volSma20 != 0 ? volume / volSma20 : 1.0
volExpScore = math.min(10.0, math.max(0.0, (volRatio - 0.5) / 1.5 * 10.0))
changePct   = close != 0 ? (close - nz(close[1])) / nz(close[1]) * 100 : 0.0
volDirScore = changePct > 0 ? volExpScore : changePct < 0 ? -volExpScore : 0.0

// Total Directional Score
dirScore    = stochScore + trendScore + volDirScore
dirScore   := math.max(-100.0, math.min(100.0, dirScore))
isBullBias  = dirScore > biasThresh
isBearBias  = dirScore < -biasThresh

// ═══════════════════════════════════════════════════════════════
// LAYER 3: Phase Persistence — Compression/Expansion duration
// ═══════════════════════════════════════════════════════════════

// Track consecutive bars in compression
var int compBars = 0
compBars := bbwp < compThresh ? compBars + 1 : 0

// Track consecutive bars in expansion/climax
var int expBars = 0
expBars := bbwp >= climThresh ? expBars + 1 : 0

// Average compression episode length (rolling estimate)
var int   totalCompEps  = 0
var int   totalCompBars_ = 0
var bool  wasInComp     = false
if bbwp < compThresh
    wasInComp := true
else if wasInComp
    totalCompEps  += 1
    totalCompBars_ += compBars[1]
    wasInComp     := false

avgCompLen = totalCompEps > 0 ? totalCompBars_ / totalCompEps : 20

// Contraction continuation score (0-100)
compContScore = 0.0
compContScore += bbwp < compThresh ? 40.0 : 0.0
compContScore += bbwpSma <= compThresh ? 15.0 : 0.0
compContScore += compBars < avgCompLen ? 15.0 : 0.0
compContScore += stKSlope <= 0 ? 10.0 : 0.0
compContScore += math.abs(dirScore) <= biasThresh ? 10.0 : 0.0
compContScore += vhmDirection <= 0 ? 10.0 : 0.0
compContScore := math.min(100.0, compContScore)

// Contraction exit score (0-100)
compExitScore = 0.0
compExitScore += compBars >= avgCompLen ? 15.0 : 0.0
compExitScore += vhmDirection == 1 ? 15.0 : 0.0
compExitScore += bbwpSma > bbwp[1] and vhmRoc > 0 ? 15.0 : 0.0
compExitScore += stKSlope > 0 and stKSmooth > stDSmooth ? 15.0 : 0.0
compExitScore += bbwp > (compThresh - 2) ? 15.0 : 0.0
compExitScore := math.min(100.0, compExitScore)

// ═══════════════════════════════════════════════════════════════
// LAYER 4: Signal Triggering
// ═══════════════════════════════════════════════════════════════

wasCompressed  = bbwp[1] <= compThresh or bbwp[2] <= compThresh or bbwp[3] <= compThresh
crossedAbove   = bbwp > compThresh
bbwpConfirm    = bbwp > bbwpSma or vhmDirection == 1
stochBull      = stKSmooth > stDSmooth and stKSlope > 0
stochBear      = stKSmooth < stDSmooth and stKSlope < 0

sigCompUp   = wasCompressed and crossedAbove and bbwpConfirm and stochBull and isBullBias
sigCompDown = wasCompressed and crossedAbove and bbwpConfirm and stochBear and isBearBias

sigExpUp    = bbwp >= climThresh and bbwpSma >= climThresh and stochBull and isBullBias
sigExpDown  = bbwp >= climThresh and bbwpSma >= climThresh and stochBear and isBearBias

// Armed state: in compression, BBWP within 3 points of threshold
isArmed = bbwp < compThresh and bbwp > (compThresh - 3)

// Signal Strength (0-100)
bbwpDist    = math.abs(bbwp - compThresh)
strengthBBWP = bbwpDist > 5 ? 30.0 : bbwpDist > 3 ? 20.0 : bbwpDist > 0 ? 10.0 : 0.0
strengthSMA  = (sigCompUp or sigCompDown) and bbwpSma > compThresh ? 20.0 : vhmDirection == 1 ? 10.0 : 0.0
absStoch     = math.abs(stSpread)
strengthStoch = absStoch >= 15 ? 25.0 : absStoch >= 10 ? 17.0 : absStoch >= 5 ? 8.0 : 0.0
strengthDir   = math.abs(dirScore) / 100.0 * 25.0

signalStrength = sigCompUp or sigCompDown or sigExpUp or sigExpDown ?
     math.min(100.0, strengthBBWP + strengthSMA + strengthStoch + strengthDir) : 0.0

// ═══════════════════════════════════════════════════════════════
// SUPPORTING ENGINES
// ═══════════════════════════════════════════════════════════════

// Breakout Readiness (0-100)
brVol  = bbwp < compThresh ? 40.0 : bbwp < 25 ? 30.0 : bbwp < 35 ? 20.0 : 0.0
brVol += isSqueeze ? 10.0 : 0.0
brAdx  = adxVal < 20 ? 10.0 : adxVal <= 25 ? 7.0 : adxVal > 30 ? 3.0 : 5.0
breakoutReadiness = math.min(100.0, brVol + brAdx)
brLabel = breakoutReadiness >= 80 ? "EXTREME" : breakoutReadiness >= 60 ? "HIGH" : breakoutReadiness >= 40 ? "MODERATE" : "LOW"

// Exhaustion Risk (0-100)
exhScore = 0.0
exhScore += bbwp > 85 ? 30.0 : 0.0
exhScore += bbwp > 95 ? 20.0 : 0.0
exhScore += stKSmooth > 80 or stKSmooth < 20 ? 20.0 : 0.0
exhScore += adxVal > 35 and vhmDirection == -1 ? 15.0 : 0.0
exhScore += vhmDirection == -1 and vhmRoc < -0.5 ? 15.0 : 0.0
exhScore := math.min(100.0, exhScore)
exhLabel = exhScore >= 80 ? "EXTREME" : exhScore >= 60 ? "HIGH" : exhScore >= 40 ? "MODERATE" : "LOW"

// Trap Detection (0-100)
trapComp   = bbwp < 10 ? 40.0 : bbwp < 15 ? 30.0 : bbwp < 20 ? 20.0 : 0.0
trapComp  += isSqueeze ? 10.0 : 0.0
trapScore  = math.min(100.0, trapComp)
isTrap     = trapScore >= 70
isTrapCand = trapScore >= 60

// ═══════════════════════════════════════════════════════════════
// LAYER 5: State Transition Prediction
// ═══════════════════════════════════════════════════════════════

transProb = 0.0
transTarget = ""
if volRegime == 1 and vhmDirection == 1
    transTarget := "transition"
    transProb   := 50 + (compThresh - bbwp) * 2
else if volRegime == 2 and vhmDirection == -1 and bbwp < 25
    transTarget := "compression"
    transProb   := 40.0
else if volRegime == 2 and vhmDirection == 1 and bbwp > 60
    transTarget := "expansion"
    transProb   := 40.0
else if volRegime == 3 and vhmDirection == 1 and bbwp > 85
    transTarget := "climax"
    transProb   := 50.0
else if volRegime == 4 and vhmDirection == -1
    transTarget := "expansion"
    transProb   := 60.0
else if volRegime == 5 and vhmDirection == 1 and bbwp > 30
    transTarget := "expansion"
    transProb   := 50.0
transProb := math.max(0.0, math.min(100.0, transProb))

// Magnitude (0-100)
magnitude = sigCompUp or sigCompDown or sigExpUp or sigExpDown ? signalStrength :
     volRegime == 1 ? compExitScore * math.abs(dirScore) / 100.0 :
     volRegime == 3 or volRegime == 4 ? (100 - exhScore) * math.abs(dirScore) / 100.0 :
     regimeConf / 100.0 * math.abs(dirScore) / 100.0 * 50.0

// ═══════════════════════════════════════════════════════════════
// FLAGS
// ═══════════════════════════════════════════════════════════════

flagBreakoutWatch   = breakoutReadiness >= 60
flagExpansionUp     = (volRegime == 3 or volRegime == 4) and isBullBias
flagExpansionDown   = (volRegime == 3 or volRegime == 4) and isBearBias
flagTrapDetected    = isTrap
flagTrapCandidate   = isTrapCand and not isTrap
flagClimaxWarning   = bbwp >= climThresh and vhmDirection <= 0
flagCompExtreme     = bbwp < 2
flagContExitRisk    = compExitScore >= 70 and volRegime == 1
flagExpExitRisk     = exhScore >= 60 and (volRegime == 3 or volRegime == 4)
flagSignalUp        = sigCompUp or sigExpUp
flagSignalDown      = sigCompDown or sigExpDown

// ═══════════════════════════════════════════════════════════════
// PHASE STATUS — Where are we in the volatility cycle?
// ═══════════════════════════════════════════════════════════════

phaseStatus = volRegime == 1 ? (compBars < avgCompLen / 2 ? "EARLY" :
     compBars < avgCompLen ? "MID" :
     compBars < avgCompLen * 1.25 ? "LATE" : "STRETCHED") :
     volRegime == 4 ? "EXTREME" :
     volRegime == 3 ? "ACTIVE" :
     volRegime == 5 ? "TRANSITION" :
     "—"

// ═══════════════════════════════════════════════════════════════
// SETUP GRADE — Quality filter for signals
// ═══════════════════════════════════════════════════════════════

setupGrade = signalStrength >= 85 and breakoutReadiness >= 75 and exhScore < 40 ? "A+" :
     signalStrength >= 75 and breakoutReadiness >= 65 and exhScore < 50 ? "A" :
     signalStrength >= 65 and breakoutReadiness >= 55 ? "B" :
     signalStrength >= 55 ? "C" :
     "D"

// ═══════════════════════════════════════════════════════════════
// ACTION ENGINE — Prescriptive verdict
// ═══════════════════════════════════════════════════════════════

action = (flagTrapDetected or exhScore >= 80) ? "AVOID" :
     ((flagSignalUp or flagSignalDown) and signalStrength >= 70 and exhScore < 60) ? "GO" :
     (isArmed or breakoutReadiness >= 60 or flagTrapCandidate) ? "WATCH" :
     "WAIT"

actionColor = action == "GO" ? color.new(#10B981, 0) :
     action == "WATCH" ? color.new(color.yellow, 0) :
     action == "AVOID" ? color.new(color.red, 0) :
     color.new(color.gray, 0)

// ═══════════════════════════════════════════════════════════════
// SIGNAL TIERS — Quality-gated markers
// ═══════════════════════════════════════════════════════════════

tier1Up   = flagSignalUp and signalStrength >= 70 and breakoutReadiness >= 60 and exhScore < 60
tier1Down = flagSignalDown and signalStrength >= 70 and breakoutReadiness >= 60 and exhScore < 60

tier2Up   = flagSignalUp and not tier1Up and signalStrength >= 55
tier2Down = flagSignalDown and not tier1Down and signalStrength >= 55

tierArmed = isArmed and breakoutReadiness >= 50

// ═══════════════════════════════════════════════════════════════
// PRESSURE RIBBON — Replaces dir histogram
// ═══════════════════════════════════════════════════════════════

pressureLevel = dirScore >= 30 ? 6.0 :
     dirScore >= biasThresh ? 5.0 :
     dirScore > 5 ? 4.0 :
     dirScore < -30 ? 1.0 :
     dirScore < -biasThresh ? 2.0 :
     dirScore < -5 ? 3.0 :
     3.5

pressureColor = dirScore >= 30 ? color.new(#10B981, 0) :
     dirScore >= biasThresh ? color.new(#10B981, 35) :
     dirScore > 5 ? color.new(#10B981, 70) :
     dirScore <= -30 ? color.new(color.red, 0) :
     dirScore <= -biasThresh ? color.new(color.red, 35) :
     dirScore < -5 ? color.new(color.red, 70) :
     color.new(color.gray, 70)

// ═══════════════════════════════════════════════════════════════
// PLOTS — Layered for visual hierarchy
// ═══════════════════════════════════════════════════════════════

// 1. Regime background (softest layer)
bgCol = showBg ? (volRegime == 1 ? color.new(color.blue, bgTransparency) :
     volRegime == 5 ? color.new(color.yellow, math.min(bgTransparency + 1, 100)) :
     volRegime == 3 ? color.new(color.orange, bgTransparency) :
     volRegime == 4 ? color.new(color.red, math.max(bgTransparency - 2, 85)) :
     na) : na
bgcolor(bgCol, title="Regime BG")

// 2. Threshold lines
hline(compThresh, "Compression", color=color.new(color.blue, 60),   linestyle=hline.style_dashed)
hline(expThresh,  "Expansion",   color=color.new(color.orange, 60), linestyle=hline.style_dashed)
hline(climThresh, "Climax",      color=color.new(color.red, 60),    linestyle=hline.style_dashed)

// 3. BBWP SMA (behind main line)
plot(bbwpSma, "BBWP SMA", color=color.new(color.white, 40), linewidth=1)

// 4. BBWP main line (primary visual)
bbwpColor = volRegime == 1 ? color.new(color.blue, 0) :
     volRegime == 5 ? color.new(color.yellow, 0) :
     volRegime == 3 ? color.new(color.orange, 0) :
     volRegime == 4 ? color.new(color.red, 0) :
     color.new(color.gray, 30)
plot(bbwp, "BBWP", color=bbwpColor, linewidth=2)

// 5. VHM histogram (mode-aware, subordinate)
vhmCol = vhmSmoothed > 0 ? (vhmDirection == 1 ? color.new(#10B981, 0) : color.new(#10B981, 60)) :
     (vhmDirection == -1 ? color.new(color.red, 0) : color.new(color.red, 60))
plot(showVHM and not isCleanMode ? vhmSmoothed * 2.5 : na, "VHM", style=plot.style_columns, color=vhmCol)

// 6. Pressure ribbon (replaces old dir histogram)
plot(showPressure and not isCleanMode ? pressureLevel : na, "Pressure Ribbon", color=pressureColor, linewidth=2)

// 7. Squeeze markers (reduced spam)
plotshape((isDiagMode or showMinorMarks) and isSqueeze, "Squeeze", shape.diamond, location.bottom, color.new(color.fuchsia, 60), size=size.tiny)
plotshape((isProMode or isDiagMode) and squeezeFiring, "Squeeze Fire", shape.triangleup, location.bottom, color.new(color.lime, 0), size=size.normal, text="SQZ")

// 8. Tiered signal markers
plotshape(tier1Up,   "Tier1 Up",   shape.triangleup,   location.top, color.new(#10B981, 0),    size=size.large, text="GO↑")
plotshape(tier1Down, "Tier1 Down", shape.triangledown, location.top, color.new(color.red, 0),   size=size.large, text="GO↓")
plotshape((isProMode or isDiagMode) and tier2Up,   "Tier2 Up",   shape.triangleup,   location.top, color.new(#10B981, 45), size=size.small)
plotshape((isProMode or isDiagMode) and tier2Down, "Tier2 Down", shape.triangledown, location.top, color.new(color.red, 45), size=size.small)
plotshape((isDiagMode or showMinorMarks) and tierArmed, "Armed", shape.circle, location.bottom, color.new(color.yellow, 15), size=size.tiny)

// 9. Exhaustion warnings (Pro/Diagnostic only)
plotshape(showExhaust and not isCleanMode and exhScore >= 60, "Exhaustion", shape.xcross, location.top, color=color.new(color.red, 20), size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// TABLE — Verdict Module
// ═══════════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 12, bgcolor=color.new(#0F172A, 8), frame_width=1, frame_color=color.new(color.gray, 70))

regimeStr = volRegime == 1 ? "COMPRESSION" : volRegime == 2 ? "NEUTRAL" : volRegime == 3 ? "EXPANSION" : volRegime == 4 ? "CLIMAX" : "TRANSITION"
biasStr   = isBullBias ? "BULLISH" : isBearBias ? "BEARISH" : "NEUTRAL"
sigStr    = sigCompUp ? "COMP RELEASE ↑" : sigCompDown ? "COMP RELEASE ↓" : sigExpUp ? "EXP CONTINUE ↑" : sigExpDown ? "EXP CONTINUE ↓" : isArmed ? "ARMED" : "—"

if barstate.islast and showTable
    // Row 0: ACTION (verdict-first)
    table.cell(dash, 0, 0, "ACTION",   text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 0, action,     text_color=actionColor, text_size=size.small)

    // Row 1: SETUP grade
    gradeColor = setupGrade == "A+" ? #10B981 : setupGrade == "A" ? color.lime : setupGrade == "B" ? color.yellow : color.gray
    table.cell(dash, 0, 1, "SETUP",    text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 1, setupGrade, text_color=gradeColor, text_size=size.small)

    // Row 2: REGIME
    regCol = volRegime == 1 ? color.aqua : volRegime == 4 ? color.red : volRegime == 3 ? color.orange : color.white
    table.cell(dash, 0, 2, "REGIME",    text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 2, regimeStr,   text_color=regCol, text_size=size.small)

    // Row 3: PHASE
    phCol = phaseStatus == "STRETCHED" ? color.red : phaseStatus == "LATE" ? color.yellow : color.white
    table.cell(dash, 0, 3, "PHASE",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 3, phaseStatus,  text_color=phCol, text_size=size.small)

    // Row 4: BBWP
    table.cell(dash, 0, 4, "BBWP",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(bbwp, "#.0"), text_color=color.white, text_size=size.small)

    // Row 5: CONF %
    table.cell(dash, 0, 5, "CONF %",    text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(regimeConf, "#.0"), text_color=color.white, text_size=size.small)

    // Row 6: BIAS
    biasCol = isBullBias ? #10B981 : isBearBias ? color.red : color.gray
    table.cell(dash, 0, 6, "BIAS",      text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 6, biasStr + " (" + str.tostring(dirScore, "#.0") + ")", text_color=biasCol, text_size=size.small)

    // Row 7: SIGNAL
    sigCol = flagSignalUp ? #10B981 : flagSignalDown ? color.red : color.gray
    table.cell(dash, 0, 7, "SIGNAL",    text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 7, sigStr,      text_color=sigCol, text_size=size.small)

    // Row 8: STRENGTH
    strCol = signalStrength >= 70 ? #10B981 : signalStrength >= 55 ? color.yellow : color.white
    table.cell(dash, 0, 8, "STRENGTH",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(signalStrength, "#.0"), text_color=strCol, text_size=size.small)

    // Row 9: BRK READY
    brCol = breakoutReadiness >= 60 ? color.yellow : color.white
    table.cell(dash, 0, 9, "BRK READY", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 9, brLabel + " (" + str.tostring(breakoutReadiness, "#.0") + ")", text_color=brCol, text_size=size.small)

    // Row 10: EXHAUST
    exCol = exhScore >= 60 ? color.red : color.white
    table.cell(dash, 0, 10, "EXHAUST",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 10, exhLabel + " (" + str.tostring(exhScore, "#.0") + ")", text_color=exCol, text_size=size.small)

    // Row 11: SQZ/TRAP
    trapStr = flagTrapDetected ? "TRAP" : flagTrapCandidate ? "WATCH" : "—"
    sqzStr  = isSqueeze ? "ON" : "—"
    stCol   = flagTrapDetected ? color.red : isSqueeze ? color.fuchsia : color.gray
    table.cell(dash, 0, 11, "SQZ/TRAP", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 11, sqzStr + " / " + trapStr, text_color=stCol, text_size=size.small)

// ═══════════════════════════════════════════════════════════════
// LAST-BAR SUMMARY LABEL (optional)
// ═══════════════════════════════════════════════════════════════

if showLastBarLbl and barstate.islast
    label.new(bar_index, bbwp, action + " | " + regimeStr + " | " + biasStr + " | " + phaseStatus,
         style=label.style_label_left,
         textcolor=color.white,
         color=color.new(#111827, 10),
         size=size.small)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(sigCompUp,          "Compression Release UP",   "DVE: Compression release bullish")
alertcondition(sigCompDown,        "Compression Release DOWN", "DVE: Compression release bearish")
alertcondition(sigExpUp,           "Expansion Continue UP",    "DVE: Expansion continuation bullish")
alertcondition(sigExpDown,         "Expansion Continue DOWN",  "DVE: Expansion continuation bearish")
alertcondition(squeezeFiring,      "Squeeze Fired",            "DVE: Squeeze just released")
alertcondition(isArmed,            "Armed",                    "DVE: Compression armed — breakout imminent")
alertcondition(exhScore >= 80,     "Exhaustion Extreme",       "DVE: Exhaustion risk EXTREME")
alertcondition(flagTrapDetected,   "Trap Detected",            "DVE: Volatility trap detected")
alertcondition(flagClimaxWarning,  "Climax Warning",           "DVE: Climax regime with deceleration")
alertcondition(action == "GO",     "Action GO",                "DVE: Action verdict is GO")
alertcondition(action == "AVOID",  "Action AVOID",             "DVE: Action verdict is AVOID")
