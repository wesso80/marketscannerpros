// Refactored into action / state / setup command module

//@version=6
indicator("MSP — Terminal Scanner", shorttitle="MSP Scanner", overlay=false, max_labels_count=300)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

grp_core = "Core Settings"
emaFastLen      = input.int(14,  "EMA Fast", minval=5, maxval=100, group=grp_core)
emaSlowLen      = input.int(25,  "EMA Slow", minval=10, maxval=200, group=grp_core)
trendLen        = input.int(200, "Trend Baseline EMA", minval=50, maxval=400, group=grp_core)

grp_momentum = "Momentum / Oscillator"
rsiLen          = input.int(14, "RSI Length", minval=5, maxval=50, group=grp_momentum)
macdFast        = input.int(12, "MACD Fast", minval=5, maxval=30, group=grp_momentum)
macdSlow        = input.int(26, "MACD Slow", minval=10, maxval=50, group=grp_momentum)
macdSignalLen   = input.int(9,  "MACD Signal", minval=3, maxval=20, group=grp_momentum)
stochLen        = input.int(14, "Stoch Length", minval=5, maxval=30, group=grp_momentum)
stochSmooth     = input.int(3,  "Stoch Smooth", minval=1, maxval=10, group=grp_momentum)

grp_volume = "Volume / Participation"
volLen          = input.int(20, "Volume SMA Length", minval=5, maxval=100, group=grp_volume)
adxLen          = input.int(14, "ADX Length", minval=5, maxval=50, group=grp_volume)

grp_dve = "Volatility / DVE Proxy"
bbLen           = input.int(13, "BB Width Length", minval=5, maxval=50, group=grp_dve)
bbLookback      = input.int(252, "BBWP Lookback", minval=50, maxval=500, group=grp_dve)
bbStd           = input.float(2.0, "BB Std Mult", minval=0.5, maxval=4.0, step=0.5, group=grp_dve)
compThreshold   = input.float(15.0, "Compression Threshold", minval=1, maxval=40, group=grp_dve)
expThreshold    = input.float(70.0, "Expansion Threshold", minval=40, maxval=95, group=grp_dve)

grp_score = "Scanner Score"
bullThreshold   = input.float(65.0, "Bull Threshold", minval=50, maxval=95, group=grp_score)
bearThreshold   = input.float(35.0, "Bear Threshold", minval=5, maxval=50, group=grp_score)
watchDistance   = input.float(10.0, "Watch Distance From Midline", minval=5, maxval=25, group=grp_score)

grp_weights = "Layer Weights"
wTrend         = input.float(38.0, "Trend Weight", minval=0, maxval=100, step=1, group=grp_weights)
wVolume        = input.float(20.0, "Volume Weight", minval=0, maxval=100, step=1, group=grp_weights)
wOsc           = input.float(14.0, "Oscillator Weight", minval=0, maxval=100, step=1, group=grp_weights)
wDVE           = input.float(15.0, "DVE Weight", minval=0, maxval=100, step=1, group=grp_weights)
wDir           = input.float(13.0, "Directional Weight", minval=0, maxval=100, step=1, group=grp_weights)

grp_rr = "Setup Quality"
minRRGood       = input.float(2.0, "Good R:R", minval=1.0, maxval=5.0, step=0.1, group=grp_rr)
minADXGood      = input.float(25.0, "ADX Strong", minval=10, maxval=50, step=1, group=grp_rr)
minADXOkay      = input.float(20.0, "ADX Medium", minval=10, maxval=50, step=1, group=grp_rr)

grp_vis = "Visual Settings"
uiMode           = input.string("Clean", "Display Mode", options=["Clean", "Pro", "Diagnostic"], group=grp_vis)
showTable        = input.bool(true, "Show Scanner Table", group=grp_vis)
showSignals      = input.bool(true, "Show Entry Markers", group=grp_vis)
showLayerPlots   = input.bool(true, "Show Layer Contribution Plots", group=grp_vis)
showMinorMarks   = input.bool(false, "Show Minor Diagnostic Marks", group=grp_vis)
showLastBarLbl   = input.bool(false, "Show Last-Bar Action Label", group=grp_vis)

// Mode flags
isCleanMode = uiMode == "Clean"
isProMode   = uiMode == "Pro"
isDiagMode  = uiMode == "Diagnostic"

// ═══════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════

clamp(v, minV, maxV) =>
    math.max(minV, math.min(maxV, v))

scaleSignedTo50(v, minV, maxV) =>
    // Maps a signed value to roughly 0..100 with 50 as center
    rng = maxV - minV
    rng == 0 ? 50.0 : clamp(((v - minV) / rng) * 100.0, 0.0, 100.0)

countBelow(src, length) =>
    cnt = 0
    for i = 1 to length
        cnt += src[i] <= src ? 1 : 0
    cnt

// ═══════════════════════════════════════════════════════════════
// CORE CALCULATIONS
// ═══════════════════════════════════════════════════════════════

// Trend structure
emaFast   = ta.ema(close, emaFastLen)
emaSlow   = ta.ema(close, emaSlowLen)
emaTrend  = ta.ema(close, trendLen)

trendRaw = 0.0
trendRaw += close > emaFast  ? 8 : close < emaFast  ? -8 : 0
trendRaw += close > emaSlow  ? 8 : close < emaSlow  ? -8 : 0
trendRaw += close > emaTrend ? 8 : close < emaTrend ? -8 : 0
trendRaw += emaFast > emaSlow ? 7 : emaFast < emaSlow ? -7 : 0
trendRaw += emaSlow > emaTrend ? 7 : emaSlow < emaTrend ? -7 : 0
trendScoreSigned = clamp(trendRaw, -wTrend, wTrend)
trendScore = scaleSignedTo50(trendScoreSigned, -wTrend, wTrend)

// Volume / participation
volSma = ta.sma(volume, volLen)
volRatio = volSma != 0 ? volume / volSma : 1.0
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

volRaw = 0.0
volRaw += volRatio > 1.5 ? 8 : volRatio > 1.2 ? 5 : volRatio < 0.8 ? -3 : 0
volRaw += adxVal >= 25 ? 7 : adxVal >= 20 ? 4 : 0
volRaw += diPlus > diMinus ? 3 : diPlus < diMinus ? -3 : 0
volumeScoreSigned = clamp(volRaw, -wVolume, wVolume)
volumeScore = scaleSignedTo50(volumeScoreSigned, -wVolume, wVolume)

// Oscillator
rsiVal = ta.rsi(close, rsiLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, macdFast, macdSlow, macdSignalLen)
stochRaw = ta.stoch(close, high, low, stochLen)
stochK = ta.sma(stochRaw, stochSmooth)

oscRaw = 0.0
oscRaw += rsiVal > 60 ? 5 : rsiVal < 40 ? -5 : 0
oscRaw += macdHist > 0 ? 5 : macdHist < 0 ? -5 : 0
oscRaw += stochK > 60 ? 4 : stochK < 40 ? -4 : 0
oscScoreSigned = clamp(oscRaw, -wOsc, wOsc)
oscScore = scaleSignedTo50(oscScoreSigned, -wOsc, wOsc)

// DVE proxy / BBWP
basis   = ta.sma(close, bbLen)
dev     = ta.stdev(close, bbLen) * bbStd
bbUpper = basis + dev
bbLower = basis - dev
bbWidth = basis != 0 ? (bbUpper - bbLower) / basis : 0.0
rawPctRank = bbLookback > 0 ? countBelow(bbWidth, bbLookback) / bbLookback * 100.0 : 50.0
bbwp = clamp(rawPctRank, 0.0, 100.0)

bbwpMom = bbwp - nz(bbwp[1])

// Opportunity vs confirmation split
dveOpportunity = bbwp < compThreshold ? 1 : bbwp < 25 ? 0.5 : 0
dveConfirmedUp = bbwp > compThreshold and bbwpMom > 0 and close > emaFast
dveConfirmedDn = bbwp > compThreshold and bbwpMom > 0 and close < emaFast

dveRaw = 0.0
dveRaw += dveConfirmedUp ? 12 : dveConfirmedDn ? -12 : 0
dveRaw += not dveConfirmedUp and not dveConfirmedDn and dveOpportunity == 1 ? (close > emaFast ? 4 : close < emaFast ? -4 : 0) : 0
dveRaw += bbwp > expThreshold ? (close > emaFast ? 3 : close < emaFast ? -3 : 0) : 0
dveScoreSigned = clamp(dveRaw, -wDVE, wDVE)
dveScore = scaleSignedTo50(dveScoreSigned, -wDVE, wDVE)

// Directional pressure
priceChg1 = close[1] != 0 ? (close - close[1]) / close[1] * 100.0 : 0.0
dirRaw = 0.0
dirRaw += priceChg1 > 0 ? 5 : priceChg1 < 0 ? -5 : 0
dirRaw += close > open ? 4 : close < open ? -4 : 0
dirRaw += close > emaFast and emaFast > emaFast[1] ? 4 : close < emaFast and emaFast < emaFast[1] ? -4 : 0
dirScoreSigned = clamp(dirRaw, -wDir, wDir)
dirScore = scaleSignedTo50(dirScoreSigned, -wDir, wDir)

// ═══════════════════════════════════════════════════════════════
// TOTAL SCORE
// ═══════════════════════════════════════════════════════════════

weightSum = wTrend + wVolume + wOsc + wDVE + wDir

totalScore = weightSum != 0 ?
     (trendScore * (wTrend / weightSum) +
      volumeScore * (wVolume / weightSum) +
      oscScore * (wOsc / weightSum) +
      dveScore * (wDVE / weightSum) +
      dirScore * (wDir / weightSum)) : 50.0

// Normalized setup state
isStrongBull = totalScore >= bullThreshold
isStrongBear = totalScore <= bearThreshold
inWatchZone  = math.abs(totalScore - 50.0) >= watchDistance and not isStrongBull and not isStrongBear

// Freshness / state
bullEntry = isStrongBull and not isStrongBull[1]
bearEntry = isStrongBear and not isStrongBear[1]
bullAging = isStrongBull and isStrongBull[1]
bearAging = isStrongBear and isStrongBear[1]

// Action engine
action = isStrongBull ? "LONG" :
     isStrongBear ? "SHORT" :
     inWatchZone ? "WATCH" :
     "PASS"

actionColor = action == "LONG" ? #10B981 :
     action == "SHORT" ? color.red :
     action == "WATCH" ? color.yellow :
     color.gray

state = bullEntry ? "NEW LONG" :
     bearEntry ? "NEW SHORT" :
     bullAging ? "ACTIVE LONG" :
     bearAging ? "ACTIVE SHORT" :
     action == "WATCH" ? "WATCHLIST" :
     "NEUTRAL"

stateColor = state == "NEW LONG" ? #10B981 :
     state == "NEW SHORT" ? color.red :
     state == "ACTIVE LONG" ? color.new(#10B981, 35) :
     state == "ACTIVE SHORT" ? color.new(color.red, 35) :
     state == "WATCHLIST" ? color.yellow :
     color.gray

// Setup label
setupLabel = bullEntry ? "Fresh Long Continuation" :
     bearEntry ? "Fresh Short Continuation" :
     bullAging ? "Trend Continuation" :
     bearAging ? "Trend Continuation" :
     inWatchZone and totalScore > 50 ? "Bull Watch" :
     inWatchZone and totalScore < 50 ? "Bear Watch" :
     "Neutral"

// RR proxy
rr = bullEntry or bullAging ? (adxVal >= 25 ? 2.2 : adxVal >= 20 ? 1.8 : 1.4) :
     bearEntry or bearAging ? (adxVal >= 25 ? 2.2 : adxVal >= 20 ? 1.8 : 1.4) :
     1.2

// Grade
setupGrade = math.abs(totalScore - 50.0) >= 25 and adxVal >= minADXGood and rr >= minRRGood ? "A" :
     math.abs(totalScore - 50.0) >= 18 and adxVal >= minADXOkay ? "B" :
     math.abs(totalScore - 50.0) >= 12 ? "C" :
     "D"

gradeColor = setupGrade == "A" ? #10B981 :
     setupGrade == "B" ? color.yellow :
     setupGrade == "C" ? color.orange :
     color.gray

// ═══════════════════════════════════════════════════════════════
// VISUAL LEVELS
// ═══════════════════════════════════════════════════════════════

scoreColor = isStrongBull ? color.new(#10B981, 0) :
     isStrongBear ? color.new(color.red, 0) :
     action == "WATCH" ? color.new(color.yellow, 0) :
     color.new(color.white, 20)

// Marker rail positions
longMarkerY  = bearThreshold - 8.0
shortMarkerY = bullThreshold + 8.0
watchBullY   = 58.0
watchBearY   = 42.0

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════

// Threshold lines
hline(50, "Midline", color=color.new(color.gray, 80), linestyle=hline.style_dotted)
hline(bullThreshold, "Bull Threshold", color=color.new(#10B981, 65), linestyle=hline.style_dashed)
hline(bearThreshold, "Bear Threshold", color=color.new(color.red, 65), linestyle=hline.style_dashed)

// Layer plots
plot(showLayerPlots and (isProMode or isDiagMode) ? trendScore : na,
     "Trend Layer", color=color.new(color.aqua, 35), linewidth=1)

plot(showLayerPlots and isDiagMode ? volumeScore : na,
     "Volume Layer", color=color.new(color.blue, 45), linewidth=1)

plot(showLayerPlots and (isProMode or isDiagMode) ? oscScore : na,
     "Osc Layer", color=color.new(color.yellow, 35), linewidth=1)

plot(showLayerPlots and isDiagMode ? dveScore : na,
     "DVE Layer", color=color.new(color.orange, 45), linewidth=1)

plot(showLayerPlots and isDiagMode ? dirScore : na,
     "Directional Layer", color=color.new(color.fuchsia, 45), linewidth=1)

// Total score line
plot(totalScore, "Scanner Score", color=scoreColor, linewidth=3)

// Entry markers placed close to rail
plotshape(showSignals and bullEntry ? longMarkerY : na,
     "New Long", shape.labelup, location.absolute, color=color.new(#10B981, 0), text="NEW LONG", size=size.small)

plotshape(showSignals and bearEntry ? shortMarkerY : na,
     "New Short", shape.labeldown, location.absolute, color=color.new(color.red, 0), text="NEW SHORT", size=size.small)

// Watch markers in Pro mode
watchBull = action == "WATCH" and totalScore > 50 and not bullEntry
watchBear = action == "WATCH" and totalScore < 50 and not bearEntry

plotshape(isProMode and showMinorMarks and watchBull ? watchBullY : na,
     "Watch Bull", shape.circle, location.absolute, color=color.new(color.yellow, 20), size=size.tiny)

plotshape(isProMode and showMinorMarks and watchBear ? watchBearY : na,
     "Watch Bear", shape.circle, location.absolute, color=color.new(color.yellow, 20), size=size.tiny)

// Optional active-state diamonds in Diagnostic mode
plotshape(isDiagMode and bullAging ? longMarkerY + 4 : na,
     "Active Long", shape.diamond, location.absolute, color=color.new(#10B981, 45), size=size.tiny)

plotshape(isDiagMode and bearAging ? shortMarkerY - 4 : na,
     "Active Short", shape.diamond, location.absolute, color=color.new(color.red, 45), size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// TABLE — SCANNER COMMAND MODULE
// ═══════════════════════════════════════════════════════════════

var table tb = table.new(position.top_right, 2, 12, bgcolor=color.new(#0F172A, 8), frame_width=1, frame_color=color.new(color.gray, 70))

if barstate.islast and showTable
    table.cell(tb, 0, 0, "ACTION", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 0, action, text_color=actionColor, text_size=size.normal, text_font_family=font.family_monospace)

    table.cell(tb, 0, 1, "STATE", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 1, state, text_color=stateColor, text_size=size.small)

    table.cell(tb, 0, 2, "SCORE", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 2, str.tostring(totalScore, "#.1"), text_color=scoreColor, text_size=size.normal, text_font_family=font.family_monospace)

    table.cell(tb, 0, 3, "GRADE", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 3, setupGrade, text_color=gradeColor, text_size=size.small)

    table.cell(tb, 0, 4, "TREND", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 4, str.tostring(trendScoreSigned, "#.1"), text_color=color.aqua, text_size=size.small)

    table.cell(tb, 0, 5, "VOL", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 5, str.tostring(volumeScoreSigned, "#.1"), text_color=color.blue, text_size=size.small)

    table.cell(tb, 0, 6, "OSC", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 6, str.tostring(oscScoreSigned, "#.1"), text_color=color.yellow, text_size=size.small)

    table.cell(tb, 0, 7, "DVE", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 7, str.tostring(dveScoreSigned, "#.1"), text_color=color.orange, text_size=size.small)

    table.cell(tb, 0, 8, "DIR", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 8, str.tostring(dirScoreSigned, "#.1"), text_color=color.fuchsia, text_size=size.small)

    table.cell(tb, 0, 9, "ADX", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 9, str.tostring(adxVal, "#.1"), text_color=adxVal >= minADXGood ? #10B981 : color.white, text_size=size.small)

    table.cell(tb, 0, 10, "SETUP", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 10, setupLabel, text_color=color.white, text_size=size.small)

    table.cell(tb, 0, 11, "R:R", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 11, str.tostring(rr, "#.1") + ":1", text_color=rr >= minRRGood ? #10B981 : color.yellow, text_size=size.small)

// ═══════════════════════════════════════════════════════════════
// OPTIONAL LAST-BAR LABEL
// ═══════════════════════════════════════════════════════════════

if showLastBarLbl and barstate.islast
    label.new(bar_index, totalScore, action + " | " + state + " | " + setupLabel,
         style=label.style_label_left,
         textcolor=color.white,
         color=color.new(#111827, 10),
         size=size.small)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(bullEntry, "New Long", "MSP Scanner: NEW LONG setup detected")
alertcondition(bearEntry, "New Short", "MSP Scanner: NEW SHORT setup detected")
alertcondition(action == "LONG", "Long State", "MSP Scanner: LONG state active")
alertcondition(action == "SHORT", "Short State", "MSP Scanner: SHORT state active")
alertcondition(action == "WATCH", "Watch State", "MSP Scanner: WATCH state active")
alertcondition(setupGrade == "A", "A Grade Setup", "MSP Scanner: A-grade setup detected")
